# Copy this file to `.env` before running `docker compose up`, then edit as needed.
# Safe to leave every value at its default for local/single-machine use. See "Change before
# any shared/multi-user deployment" below for the ones you should not leave as-is.

# Host paths that get bind-mounted into the containers as /data/inputs and /data/outputs.
# Requests reference scans by their IN-CONTAINER path (e.g. "/data/inputs/my_scan"), not the
# host path set here — see docs/api-reference.md and examples/python/submit_jobs.py.
INPUT_DIR=./data/inputs
OUTPUT_DIR=./data/outputs

# Hostname/IP the frontend uses to reach the backend (baked into VITE_BACKEND_URI below).
# "localhost" only works if you're opening the frontend on the same machine docker compose
# runs on. For a server/remote deployment, set this to that machine's real IP or hostname —
# otherwise the frontend in your browser won't be able to reach the backend.
HOST_IP=localhost

# Host ports for each service. Defaults below are unlikely to collide with common local
# services, but check `docker compose up` output for "port is already allocated" errors and
# change the relevant one here if needed. No two services should ever share a port.
FRONTEND_PORT=5000
BACKEND_PORT=5001
CONQUEST_FRONTEND_PORT=5002
MONGO_EXPRESS_PORT=5003
MONGO_PORT=5004
REDIS_PORT=5005
CONQUEST_DATA_PORT=5006

VITE_BACKEND_URI=https://${HOST_IP}:${BACKEND_PORT}

# NOTE: these are not currently wired up to anything — docker-compose.yml hardcodes the
# worker replica counts (gpu-workers: 1, cpu-workers: 2) instead of reading these. Changing
# them here has no effect; to change worker counts, edit the `replicas:` values in
# docker-compose.yml directly, or pass `--scale gpu-workers=N` to `docker compose up`.
NUM_GPU_WORKERS=1
NUM_CPU_WORKERS=2

# Enables Flask's auto-reload (so backend/src edits apply live, per CLAUDE.md) — leave this on
# for development. Note this does NOT leak tracebacks into API responses (the backend
# registers its own error handlers for that in app.py); it only affects server-side logging
# and auto-reload behaviour.
FLASK_DEBUG=True

# Mongo root credentials. The defaults below work fine for local/single-machine use, since
# Mongo is only reachable from other containers on the "abc" docker network plus whatever host
# port MONGO_PORT exposes. Change these before deploying anywhere the Mongo port might be
# reachable by anyone other than you (e.g. a shared server, or a host with a public IP).
MONGO_INITDB_ROOT_USERNAME=abc-user
MONGO_INITDB_ROOT_PASSWORD=abc-toolkit
MONGO_INITDB_DATABASE=db

# Login for the mongo-express web UI (a raw database browser/editor) at MONGO_EXPRESS_PORT.
# Same guidance as above — change these before deploying anywhere beyond your own machine.
MONGOEXPRESS_LOGIN=dev
MONGOEXPRESS_PASSWORD=dev
